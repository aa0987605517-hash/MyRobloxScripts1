-- 【新增功能：精準手動輸入速度】
MainSection:NewTextBox("精準設定移動速度 (WalkSpeed)", "輸入任意數字後按 Enter", function(text)
    local num = tonumber(text)
    if num and LocalPlayer.Character then
        local humanoid = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if humanoid then humanoid.WalkSpeed = num end
    end
end)

MainSection:NewSlider("移動速度調速桿 (WalkSpeed)", "", 250, 16, function(v) if LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid") then LocalPlayer.Character:FindFirstChildOfClass("Humanoid").WalkSpeed = v end end)
MainSection:NewSlider("跳躍高度設定 (JumpPower)", "", 300, 50, function(v) if LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid") then LocalPlayer.Character:FindFirstChildOfClass("Humanoid").JumpPower = v end end)

