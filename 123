-- 5. 雙快捷鍵偵聽綁定 (K 鍵與 Insert 鍵)
-- ==========================================
UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == Enum.KeyCode.K or input.KeyCode == Enum.KeyCode.Insert then 
        Window:ToggleUI() 
    end
end)

