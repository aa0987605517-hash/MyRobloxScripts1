local Window = YieldingHub:CreateWindow("Yielding Hub | Customized V2")
local Players = game:GetService("Players")
local Camera = workspace.CurrentCamera

local flying, flySpeed, bv, bg, flyConnection = false, 50, nil, nil, nil
local antiFlingEnabled, antiFlingConnection = false, nil
local espMasterEnabled, espBoxEnabled, espNameEnabled, espHealthEnabled, espTracerEnabled = false, false, false, false, false
local cache = {}
local aimbotEnabled, aimbotTeamCheck, aimbotPart, isAiming = false, false, "Head", false

-- ==========================================
-- 3. 本機操控功能實作 (移動、飛行、反彈)
-- ==========================================
local function startFlying()
    local character = LocalPlayer.Character
    local root = character and character:FindFirstChild("HumanoidRootPart")
    local humanoid = character and character:FindFirstChildOfClass("Humanoid")
    if not root or not humanoid then return end
    humanoid.PlatformStand = true
    bg = Instance.new("BodyGyro") bg.P = 9e4 bg.maxTorque = Vector3.new(9e9, 9e9, 9e9) bg.cframe = root.CFrame bg.Parent = root
    bv = Instance.new("BodyVelocity") bv.velocity = Vector3.new(0, 0, 0) bv.maxForce = Vector3.new(9e9, 9e9, 9e9) bv.Parent = root
    flyConnection = RunService.RenderStepped:Connect(function()
        if not flying or not root then if flyConnection then flyConnection:Disconnect() end return end
        bg.cframe = Camera.CFrame
        local direction = Vector3.new(0, 0, 0)
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then direction = direction + Camera.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then direction = direction - Camera.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then direction = direction - Camera.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then direction = direction + Camera.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then direction = direction + Vector3.new(0, 1, 0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then direction = direction - Vector3.new(0, 1, 0) end
        bv.velocity = direction.Magnitude > 0 and direction.Unit * flySpeed or Vector3.new(0, 0, 0)
    end)
end

local function stopFlying()
    flying = false
    if flyConnection then flyConnection:Disconnect() end
    if bv then bv:Destroy() end if bg then bg:Destroy() end
    local humanoid = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
    if humanoid then humanoid.PlatformStand = false end
end

local function toggleAntiFling(enabled)
    antiFlingEnabled = enabled
    if antiFlingConnection then antiFlingConnection:Disconnect() end
    if antiFlingEnabled then
        antiFlingConnection = RunService.Stepped:Connect(function()
            if not antiFlingEnabled then return end
            local char = LocalPlayer.Character
            if not char then return end
            for _, part in ipairs(char:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                    if part.Velocity.Magnitude > 60 or part.RotVelocity.Magnitude > 60 then
                        part.Velocity, part.RotVelocity = Vector3.new(0,0,0), Vector3.new(0,0,0)
                    end
                end
            end
        end)
    end
end

-- 自瞄鎖定邏輯
local function getClosestPlayerToCursor()
    local closestPlayer, shortestDistance = nil, math.huge
    local mousePos = UserInputService:GetMouseLocation()
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and not (aimbotTeamCheck and player.Team == LocalPlayer.Team) then
            local character = player.Character
            local part = character and character:FindFirstChild(aimbotPart)
            local humanoid = character and character:FindFirstChildOfClass("Humanoid")
            if part and humanoid and humanoid.Health > 0 then
                local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
                if onScreen then
                    local distance = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                    if distance < shortestDistance then
                        shortestDistance = distance
                        closestPlayer = player
                    end
                end
            end
        end
    end
    return closestPlayer
end

RunService.RenderStepped:Connect(function()
    if aimbotEnabled and isAiming then
        local target = getClosestPlayerToCursor()
        local part = target and target.Character and target.Character:FindFirstChild(aimbotPart)
        if part then
            Camera.CFrame = CFrame.new(Camera.CFrame.Position, part.Position)
        end
    end
end)

UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if aimbotEnabled and input.UserInputType == Enum.UserInputType.MouseButton2 then isAiming = true end
end)
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton2 then isAiming = false end
end)

-- 透視圖層邏輯
local function createESP(player)
    if player == LocalPlayer or cache[player] then return end
    local objects = {Box = Drawing.new("Square"), Tracer = Drawing.new("Line"), NameLabel = Drawing.new("Text"), HealthLabel = Drawing.new("Text")}
    cache[player] = objects
    objects.Box.Thickness, objects.Box.Filled, objects.Box.Color = 1.5, false, Color3.fromRGB(240, 84, 84)
    objects.Tracer.Thickness, objects.Tracer.Color = 1, Color3.fromRGB(255, 255, 255)
    for _, l in ipairs({objects.NameLabel, objects.HealthLabel}) do
        l.Size, l.Center, l.Outline, l.OutlineColor, l.Color = 13, true, true, Color3.fromRGB(0,0,0), Color3.fromRGB(255,255,255)
    end
    objects.HealthLabel.Color = Color3.fromRGB(0, 255, 100)
end

RunService.RenderStepped:Connect(function()
    for player, objs in pairs(cache) do
        local character = player.Character
        local root = character and character:FindFirstChild("HumanoidRootPart")
        local head = character and character:FindFirstChild("Head")
        local humanoid = character and character:FindFirstChildOfClass("Humanoid")
        local visible = false
        if espMasterEnabled and character and root and head and humanoid and humanoid.Health > 0 then
            if not (espTeamCheck and player.Team == LocalPlayer.Team) then
                local hrpPos, onScreen = Camera:WorldToViewportPoint(root.Position)
                if onScreen then
                    visible = true
                    local headPos = Camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0))
                    local legPos = Camera:WorldToViewportPoint(root.Position - Vector3.new(0, 3, 0))
                    local boxHeight = math.abs(headPos.Y - legPos.Y)
                    local boxWidth = boxHeight * 0.6
                    
                    objs.Box.Visible = espBoxEnabled
                    if espBoxEnabled then objs.Box.Size, objs.Box.Position = Vector2.new(boxWidth, boxHeight), Vector2.new(hrpPos.X - boxWidth / 2, hrpPos.Y - boxHeight / 2) end
                    
                    objs.Tracer.Visible = espTracerEnabled
                    if espTracerEnabled then objs.Tracer.From, objs.Tracer.To = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y), Vector2.new(hrpPos.X, hrpPos.Y + (boxHeight / 2)) end
                    
                    local topY, botY = hrpPos.Y - (boxHeight / 2) - 16, hrpPos.Y + (boxHeight / 2) + 2
                    objs.NameLabel.Visible = espNameEnabled if espNameEnabled then objs.NameLabel.Text, objs.NameLabel.Position = player.DisplayName or player.Name, Vector2.new(hrpPos.X, topY) end
                    objs.HealthLabel.Visible = espHealthEnabled if espHealthEnabled then objs.HealthLabel.Text, objs.HealthLabel.Position = string.format("HP: %d", humanoid.Health), Vector2.new(hrpPos.X, botY) end
                end
            end
        end
        if not visible then pcall(function() for _, o in pairs(objs) do o.Visible = false end end) end
    end
end)
for _, p in ipairs(Players:GetPlayers()) do createESP(p) end
Players.PlayerAdded:Connect(createESP)

